# World Cup Pool example configuration
# Copy this file to .env and replace placeholder values before running.

# Host port used by docker-compose.yml. The app listens on 8090 inside the container.
HTTP_PORT=8090

# Optional public origin used for social sharing metadata (og:image) and for
# links in notification emails. Falls back to the PocketBase Application URL if
# left empty. Set this in production if the app is behind a reverse proxy.
# PUBLIC_APP_URL=https://vm.midttunet.no

# Set to 1 only for local simulation tools and bot generation.
WMP_DEV=0

# Result source selection:
# - auto: use API-Football if configured and usable, otherwise openfootball
# - openfootball: community JSON data, no key required
# - apifootball: force API-Football
RESULTS_SOURCE=auto

# Optional. Leave empty to use openfootball/manual result updates.
API_FOOTBALL_KEY=

# Optional. Enables real bookmaker win-probability display on match cards (H/D/A %).
# Free tier: 500 requests/month — one daily sync uses ~31 requests for the tournament.
# Get a free key at https://the-odds-api.com
# Leave empty to use FIFA-ranking-based probability estimates instead.
ODDS_API_KEY=

# Optional PocketBase bootstrap admin. You can also create a superuser manually.
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=

# Email address that receives an alert on each new user signup.
# Requires PocketBase SMTP to be configured (see Section 4 of DEPLOY.md).
# Falls back to PB_ADMIN_EMAIL if left empty.
SIGNUP_ALERT_EMAIL=

# Optional bearer token that enables GET /api/public/stats for external
# monitoring tools such as Home Assistant. Leave empty to disable the endpoint.
PUBLIC_STATS_TOKEN=

# --- User notifications (opt-in email + Web Push) ---------------------------
# Turn on automatic sending (pre-kickoff reminder 1 day before the first match,
# and "matches starting soon you haven't tipped"). Off by default so a deploy
# can ship dark; flip to 1 once verified. The send log dedups, so the 15-min
# cron never double-sends.
NOTIFY_CRON_ENABLED=0

# Web Push VAPID keys. If left empty the app generates a pair on first boot and
# stores it in app_meta (carried by backup/restore). Set them explicitly in
# production so the keys are stable and independent of the database. Generate a
# pair once and keep them secret.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact for the push "Subscriber" field (mailto: or https URL). Falls back to
# the configured SMTP sender address.
# PUSH_SUBJECT=mailto:admin@example.com

# Optional Google OAuth login. Leave empty to use email/password only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
