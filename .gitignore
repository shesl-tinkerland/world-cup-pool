# Go
/wm-pickems
/tmp/

# PocketBase runtime data (DB, storage, logs)
/pb_data/
/pb_data_dev/

# Node / SvelteKit
frontend/node_modules/
frontend/.svelte-kit/
frontend/build/
frontend/playwright-report/
frontend/test-results/

# Embedded build output — generated by the frontend build, not committed.
# Only an empty .gitkeep is tracked so `//go:embed all:build` compiles
# without a frontend build (and so a build never dirties git status).
/internal/web/build/*
!/internal/web/build/.gitkeep

# Env
.env
*.local

# Secret backups / local data snapshots
pb_data-backup-*.tgz
*.tar.gz
*.dpapi.json
pb_data_smoke/
*.db
*.sqlite
*.sqlite3
*.log

# Local operations data
/backups/

# Local production backup automation
/scripts/backup-prod.ps1
/scripts/register-backup-task.ps1

# Local editor config
.vscode/settings.json
.vscode/extensions.json

# Temporary / backup files
*.bak
*.tmp
*~

# Editor / OS
.DS_Store
.directory
